# ============================================================
# TeamSpeak AI Backend — 环境变量配置模板
# ============================================================
# 复制此文件为 .env 并按需修改。
#
# 三个服务各自有独立配置，通过 🔗 标注需要跨服务对齐的参数。
# 改动 🔗 参数时，必须同步修改对应服务的配置，否则通信会断。
#
# 服务配置文件位置：
#   Python 后端  → team-speak-ai/backend/config.py + .env
#   Java Bridge  → team-speak-bot/src/main/resources/application.properties
#   Vue 前端     → team-speak-ai/frontend/.env.development + pipeline.js

# ── Server ──────────────────────────────────────────────────
# host=0.0.0.0
# port=8000
# debug=false

# ── TeamSpeak Bridge 连接 ───────────────────────────────────
# 🔗 TS_WS_URL 必须与 Java application.properties 的
#    websocket.port(8080) + websocket.path(/teamspeak/voice) 一致
ts_ws_url=ws://localhost:8080/teamspeak/voice

# Python→Java WS 重连间隔（秒），指数退避上限 30s
# ts_reconnect_interval=5

# 🔗 心跳间隔（秒），必须与 Java application.properties 的
#    heartbeat.interval-seconds 一致（当前值：30）
# ts_heartbeat_interval=30

# ── 前端 WebSocket 心跳 ─────────────────────────────────────
# 🔗 前端 pipeline.js 的 HEARTBEAT_TIMEOUT 应与此值一致（90000ms = 90s）
#    前端 HEARTBEAT_INTERVAL（30000ms）的 3 倍应 ≤ 此值
# ws_heartbeat_timeout=90

# ── CORS 允许来源 ───────────────────────────────────────────
# 逗号分隔的允许来源列表，部署生产环境时需添加生产域名
# cors_origins=http://localhost:5173,http://127.0.0.1:5173

# ── WS 鉴权 ────────────────────────────────────────────────
# 🔗 前端 VITE_WS_AUTH_TOKEN 必须与此值一致
# 空 = 不校验（开箱即用）；设置后前端连接时必须带 ?token=xxx
# ws_auth_token=

# ── STT（语音转文字）────────────────────────────────────────
# 可选值：sensevoice, whisper, minimax
stt_provider=sensevoice

# SenseVoice（本地 STT - 阿里开源）
# sensevoice_model=iic/SenseVoiceSmall
# sensevoice_device=cpu

# Whisper（本地 STT）
# whisper_model=base
# whisper_device=cuda

# MiniMax STT（云端）
minimax_api_key=
# minimax_api_url=https://api.minimax.chat/v1
# minimax_model=speech-01

# ── TTS（文字转语音）────────────────────────────────────────
# 可选值：edge, minimax
tts_provider=edge

# MiniMax TTS
minimax_tts_model=speech-2.8-hd
minimax_voice_id=male-qn-qingse
# minimax_speed=1.0
# minimax_vol=1

# ── LLM（大语言模型）────────────────────────────────────────
# 可选值：openai（OpenAI 兼容接口，指向 MiniMax）
llm_provider=openai

openai_api_key=
openai_base_url=https://api.minimaxi.com/v1
openai_model=MiniMax-M2.7
# openai_reasoning_split=true

# ── OCR（图文识别）───────────────────────────────────────────
# 可选值：easyocr, paddleocr
ocr_provider=easyocr

# PaddleOCR
# paddleocr_det_model=ch
# paddleocr_rec_model=ch
# paddleocr_use_angle_cls=true
# paddleocr_use_gpu=false

# ── Pipeline ────────────────────────────────────────────────
# pipeline_config_dir=config/pipelines

# ── 数据与存储 ──────────────────────────────────────────────
# data_dir=./data
# upload_dir=./data/uploads
# max_file_size=10485760       # 10MB
# max_upload_size=104857600    # 100MB

# ── 日志 ────────────────────────────────────────────────────
# log_provider=file
# log_dir=logs
# log_keep_days=30
