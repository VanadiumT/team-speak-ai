# ============================================================
# TeamSpeak AI Backend — Environment Configuration
# Copy to .env and fill in your values.
# ============================================================

# ── Server ─────────────────────────────────────────────────
# host=0.0.0.0
# port=8000
# debug=false

# ── TeamSpeak Bridge ───────────────────────────────────────
ts_ws_url=ws://localhost:8080/teamspeak/voice

# ── STT (Speech-to-Text) ─────────────────────────────────
# Provider: sensevoice | whisper | minimax
stt_provider=sensevoice

# SenseVoice (local, FunASR)
# sensevoice_model=iic/SenseVoiceSmall
# sensevoice_device=cpu

# Whisper (local)
# whisper_model=base
# whisper_device=cuda

# MiniMax STT (cloud)
minimax_api_key=
# minimax_api_url=https://api.minimax.chat/v1
# minimax_model=speech-01

# ── TTS (Text-to-Speech) ──────────────────────────────────
# Provider: edge | minimax
tts_provider=edge

# MiniMax TTS (cloud)
minimax_tts_model=speech-2.8-hd
minimax_voice_id=male-qn-qingse
# minimax_speed=1.0
# minimax_vol=1

# ── LLM ───────────────────────────────────────────────────
# Provider: openai (MiniMax OpenAI-compatible)
llm_provider=openai

openai_api_key=
openai_base_url=https://api.minimaxi.com/v1
openai_model=MiniMax-M2.7
# openai_reasoning_split=true

# ── OCR ───────────────────────────────────────────────────
# Provider: easyocr | paddleocr
ocr_provider=easyocr

# PaddleOCR
# paddleocr_det_model=ch
# paddleocr_rec_model=ch
# paddleocr_use_angle_cls=true
# paddleocr_use_gpu=false

# ── Data ──────────────────────────────────────────────────
# pipeline_config_dir=config/pipelines
# data_dir=./data
# upload_dir=./data/uploads

# ── Logging ───────────────────────────────────────────────
# log_provider=file
# log_dir=logs
# log_keep_days=30

# ── WebSocket ─────────────────────────────────────────────
# ws_max_connections_per_ip=5
